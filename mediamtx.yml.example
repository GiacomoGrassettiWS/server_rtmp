# Configurazione MediaMTX per OBS
# File di esempio - verrà generato automaticamente dall'applicazione

# Livello di log
logLevel: info
logDestinations: [stdout]

# Configurazione RTMP
rtmpAddress: :1935
rtmp: yes

# Configurazione HLS (per web player)
hlsAddress: :8888
hls: yes
hlsAlwaysRemux: yes

# Configurazione dei percorsi
# Configurazione aperta senza autenticazione
paths:
  all:
    
# Esempio con autenticazione (decommentare per usare)
# paths:
#   private:
#     publishUser: admin
#     publishPass: secret123
